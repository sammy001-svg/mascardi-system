{
    "name": "mascardi/car-yard-system",
    "description": "Mascardi Luxury Cars — Car Yard Management System",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "dompdf/dompdf": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Mascardi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mascardi\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
